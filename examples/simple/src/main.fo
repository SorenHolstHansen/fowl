use simple.utils.add
use std.io.println

fn main() void {
	let n = 100
	let n_p_one = n + 1
	let sum = n * n_p_one / 2
    let square_of_sum = sum * sum
	let mut sum_of_squares = 0
	let mut i = 1
	for (i <= n) {
		sum_of_squares = sum_of_squares + i * i
		i = i + 1
	}
    let res = square_of_sum - sum_of_squares

	println("res = {res}")
}
